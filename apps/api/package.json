{
	"name": "@cruxi/api",
	"version": "1.0.0",
	"exports": {
		".": "./router.type.ts"
	},
	"scripts": {
		"dev": "bun --watch index.ts",
		"check-types": "tsc --noEmit",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "bun ./src/database/seed.ts",
		"db:dev": "bun run db:push && bun run db:seed",
		"db:recreate": "docker compose down -v && docker compose up -d --wait && bun run db:dev"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.10",
		"@better-auth/expo": "^1.6.10",
		"@orpc/client": "^1.13.13",
		"@orpc/server": "^1.13.13",
		"better-auth": "^1.6.10",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.2",
		"drizzle-seed": "^0.3.1",
		"pg": "^8.20.0",
		"zod": "^4.3.6"
	}
}
