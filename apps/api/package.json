{
	"name": "@cruxi/api",
	"version": "1.0.0",
	"scripts": {
		"dev": "bun --watch index.ts",
		"type:check": "tsc --noEmit",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "bun ./src/database/seed.ts",
		"db:dev": "bun run db:migrate && bun run db:push && bun run db:seed",
		"db:dev:reset": "docker compose down -v && docker compose up -d --wait && bun run db:dev"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10"
	},
	"dependencies": {
		"@cruxi/contract": "workspace:*",
		"@better-auth/drizzle-adapter": "^1.6.11",
		"@better-auth/expo": "^1.6.11",
		"@orpc/client": "^1.14.3",
		"@orpc/server": "^1.14.3",
		"better-auth": "^1.6.11",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"drizzle-seed": "^0.3.1",
		"pg": "^8.21.0",
		"zod": "^4.4.3"
	}
}
