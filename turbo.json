{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"outputs": ["dist/**"]
		},
		"type:check": {
			"dependsOn": ["^type:check"]
		},
		"dev": {
			"persistent": true,
			"interactive": true,
			"cache": false
		},
		"setup": {
			"dependsOn": ["^setup"]
		},
		"db:setup": {
			"dependsOn": ["^db:setup"],
			"cache": false
		}
	}
}
